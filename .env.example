# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Scraping Configuration
SCRAPER_TIMEOUT=45000
SCRAPER_RETRIES=3
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5

# ChromaDB Configuration
CHROMA_DB_PATH=./chromadb_data
CHROMA_COLLECTION_NAME=fashion_catalog

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Cache Configuration
CACHE_TTL_HOURS=1

# Logging
LOG_LEVEL=INFO
